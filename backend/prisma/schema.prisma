generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id           String   @id @default(cuid())
  name         String
  headId       String?
  head         Employee? @relation("DeptHead", fields: [headId], references: [id])
  parentDeptId String?
  parentDept   Department? @relation("DeptHierarchy", fields: [parentDeptId], references: [id])
  childDepts   Department[] @relation("DeptHierarchy")
  status       String   @default("Active")
  employees    Employee[] @relation("EmployeeDept")
  assets       Asset[]
}

model Category {
  id           String   @id @default(cuid())
  name         String
  customFields Json?
  assets       Asset[]
}

model Employee {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  departmentId   String?
  department     Department? @relation("EmployeeDept", fields: [departmentId], references: [id])
  role           String   @default("Employee") // Employee, DeptHead, AssetManager, Admin
  status         String   @default("Active")
  headOf         Department[] @relation("DeptHead")
  allocations    Allocation[]
  createdAt      DateTime @default(now())

  // Relations for Dev B
  bookings            Booking[]
  reportedMaintenance MaintenanceRequest[] @relation("MaintReporter")
  assignedMaintenance MaintenanceRequest[] @relation("MaintAssignee")
  auditAssignments    AuditAssignment[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
}

model Asset {
  id             String   @id @default(cuid())
  tag            String   @unique
  name           String
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  serialNumber   String?
  acquisitionDate DateTime?
  acquisitionCost Float?
  condition      String?
  location       String?
  photoUrl       String?
  isBookable     Boolean  @default(false)
  status         String   @default("Available")
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  allocations    Allocation[]
  transfers      TransferRequest[]
  createdAt      DateTime @default(now())

  // Relations for Dev B
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditDiscrepancies  AuditDiscrepancy[]
}

model Allocation {
  id                 String   @id @default(cuid())
  assetId            String
  asset              Asset    @relation(fields: [assetId], references: [id])
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id])
  departmentId       String?
  allocatedDate      DateTime @default(now())
  expectedReturnDate DateTime?
  returnedDate       DateTime?
  conditionOnReturn  String?
  status             String   @default("Active")
}

model TransferRequest {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id])
  fromEmployeeId String
  toEmployeeId   String
  reason         String?
  status         String   @default("Requested")
  requestedBy    String
  approvedBy     String?
  createdAt      DateTime @default(now())
}

model Booking {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  startTime     DateTime
  endTime       DateTime
  purpose       String?
  status        String   @default("Confirmed") // Confirmed, Cancelled, Completed
  createdAt     DateTime @default(now())
}

model MaintenanceRequest {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id])
  reportedBy     String
  reporter       Employee @relation("MaintReporter", fields: [reportedBy], references: [id])
  issueDescription String
  status         String   @default("Pending") // Pending, Approved, Rejected, Assigned, InProgress, Resolved
  assignedTo     String?
  assignee       Employee? @relation("MaintAssignee", fields: [assignedTo], references: [id])
  approvedBy     String?
  resolutionNotes String?
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?
}

model AuditCycle {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("Open") // Open, Closed
  createdBy    String
  startDate    DateTime @default(now())
  closedDate   DateTime?
  discrepancies AuditDiscrepancy[]
  auditors     AuditAssignment[]
}

model AuditAssignment {
  id           String   @id @default(cuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  auditorId    String
  auditor      Employee @relation(fields: [auditorId], references: [id])
}

model AuditDiscrepancy {
  id           String   @id @default(cuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  expectedStatus String
  actualStatus   String
  notes        String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  employeeId String
  employee  Employee @relation(fields: [employeeId], references: [id])
  message   String
  type      String   // e.g. "MaintenanceAssigned", "BookingConfirmed", "TransferApproved"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       Employee @relation(fields: [actorId], references: [id])
  actionType  String   // Matches Dev A's actionType column
  entityType  String   // e.g. "Asset", "Booking"
  entityId    String
  description String?  // Matches Dev A's description column
  timestamp   DateTime @default(now()) // Matches Dev A's timestamp column
}
